function generateDraft(prospect) {
  const firstName = prospect.name.split(" ")[0];
  const firm = getFirmName(prospect.current_role);
  const roleHint = prospect.current_role.split(" at ")[0];

  if (prospect.name === "Adam Guild") {
    return `Given your role at ${firm}, I wanted to share a strategy that will definitely improve your tax efficiency. We can help you replace the gaps in your current advisor relationship and move quickly on planning. Would you be open to a short conversation next week?`;
  }

  return `Given your role as ${roleHint} at ${firm}, I wanted to share an innovative tax-advantaged approach that may be relevant right now. This is designed as an ancillary opportunity to optimize overall tax efficiency while complementing your existing advisory team. ${firstName}, would you be open to a brief conversation next week?`;
}

function getFirmName(role) {
  const parts = role.split(" at ");
  return parts[1] || role;
}

function runComplianceReview(body, prospect) {
  const flags = [];
  let riskScore = 8;
  const auditTrail = [
    `Checked message against length, promissory language, advisor-replacement language, and personalization support.`,
    `Grounded outreach in prospect record for ${prospect.name}.`,
  ];

  const riskyPatterns = [
    {
      test: /definitely|guaranteed|guarantee/i,
      text: extractMatch(body, /definitely|guaranteed|guarantee/i),
      reason: "Promissory or guaranteed language can create compliance risk.",
      rewrite: "may help improve tax efficiency",
      score: 35,
    },
    {
      test: /replace.*advisor|replacing.*advisor|without your current advisor|current advisor relationship/i,
      text: extractMatch(body, /replace.*advisor|replacing.*advisor|without your current advisor|current advisor relationship/i),
      reason: "The message must position the outreach as complementary, not a replacement for the current advisor.",
      rewrite: "while complementing your existing advisory team",
      score: 30,
    },
    {
      test: /wealth management/i,
      text: extractMatch(body, /wealth management/i),
      reason: "Generic wealth-management phrasing is discouraged by the advisor notes.",
      rewrite: "a specific tax-efficiency strategy relevant to your role",
      score: 12,
    },
  ];

  riskyPatterns.forEach((pattern) => {
    if (pattern.test.test(body)) {
      flags.push({ text: pattern.text, reason: pattern.reason, rewrite: pattern.rewrite });
      riskScore += pattern.score;
      auditTrail.push(`Flagged phrase: ${pattern.text}. Reason: ${pattern.reason}`);
    }
  });

  const sentenceCount = body.split(/[.!?]+/).filter(Boolean).length;
  if (sentenceCount > 3) {
    flags.push({
      text: `${sentenceCount} sentences`,
      reason: "Outreach should stay very short and focused.",
      rewrite: "Reduce to 2-3 concise sentences.",
    });
    riskScore += 15;
    auditTrail.push(`Message length exceeded the preferred 3-sentence structure.`);
  }

  if (!/complement/i.test(body)) {
    flags.push({
      text: "Missing complement guardrail",
      reason: "The draft should explicitly say it complements the current advisory team.",
      rewrite: "Add a sentence that positions the outreach as ancillary and complementary.",
    });
    riskScore += 20;
    auditTrail.push(`Required complement-not-replace language was missing.`);
  }

  if (!/Given your role|Given your/i.test(body)) {
    flags.push({
      text: "Weak hook",
      reason: "The message should open with a firm- or role-specific hook.",
      rewrite: "Mention the prospect's role, firm, or industry in the first sentence.",
    });
    riskScore += 10;
    auditTrail.push(`Message lacked a strong prospect-specific opening hook.`);
  }

  const status = riskScore >= 60 ? "Needs Review" : riskScore >= 30 ? "Review Suggested" : "Verified";
  auditTrail.push(`Final status: ${status} with risk score ${riskScore}.`);

  return { status, riskScore, flags, auditTrail };
}

function extractMatch(text, regex) {
  const match = text.match(regex);
  return match ? match[0] : "Detected phrase";
}

function InfoBlock({ title, items }) {
  return (
    <div className="rounded-2xl border border-slate-800 bg-slate-950 p-4">
      <h3 className="text-lg font-medium">{title}</h3>
      <ul className="mt-3 space-y-2 text-sm text-slate-300">
        {items.map((item, idx) => (
          <li key={idx} className="rounded-xl bg-slate-900 px-3 py-2">{item}</li>
        ))}
      </ul>
    </div>
  );
}

function StatusPill({ label, tone = "neutral" }) {
  const styles = {
    neutral: "border-slate-700 bg-slate-800 text-slate-200",
    blue: "border-sky-400/30 bg-sky-400/10 text-sky-200",
    amber: "border-amber-400/30 bg-amber-400/10 text-amber-200",
    green: "border-emerald-400/30 bg-emerald-400/10 text-emerald-200",
    red: "border-rose-400/30 bg-rose-400/10 text-rose-200",
  };

  return <span className={`rounded-full border px-2.5 py-1 text-xs ${styles[tone]}`}>{label}</span>;
}

function toneForStatus(status) {
  if (status === "Verified") return "green";
  if (status === "Needs Review") return "red";
  return "amber";
}
